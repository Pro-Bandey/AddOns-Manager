{
  "manifest_version": 3,
  "name": "AddOns Manager",
  "short_name": "AddOns Manager",
  "version": "1.0.1",
  "description": "Manage and control your browser extensions more easily",

  "icons": {
    "16": "assets/icons/icon-16.png",
    "38": "assets/icons/icon-32.png",
    "128": "assets/icons/icon-128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["/assets/js/angular.min.js", "/assets/js/main.js"],
      "matches": ["<all_urls>"]
    }
  ],

  "permissions": ["management", "storage"],

  "action": {
    "default_icon": "/assets/icons/icon-20.png",
    "default_popup": "popup.html"
  }
}
